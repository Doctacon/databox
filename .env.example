# Databox Environment Configuration

# Backend: "local" (default) or "motherduck"
DATABOX_BACKEND=local

# SQLMesh gateway: "local" (default) or "motherduck"
# Should match DATABOX_BACKEND setting
DATABOX_GATEWAY=local

# MotherDuck (only needed when DATABOX_BACKEND=motherduck)
MOTHERDUCK_TOKEN=

# Database (DuckDB — file-based, no server required)
# Overrides the default path when DATABOX_BACKEND=local
DUCKDB_PATH=data/databox.duckdb

# DLT Configuration
DLT_DATA_DIR=data/dlt

# Logging
LOG_LEVEL=INFO

# Pipeline API Keys (add keys for each registered pipeline)
EBIRD_API_TOKEN=your_ebird_api_token_here
NOAA_API_TOKEN=your_noaa_api_token_here
