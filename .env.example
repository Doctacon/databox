# Databox Environment Configuration
#
# All runtime config is declared in databox/config/settings.py. Variables
# listed below are the ones that file reads. Keep this example in sync
# with DataboxSettings — no other files read config.

# Quack loads all dlt sources into data/databox.duckdb through one local server.

# Quack local server (only needed when overriding defaults)
# DATABOX_QUACK_URI=quack:localhost:9494
# DATABOX_QUACK_TOKEN=databox_quack_token

# Logging / local privacy defaults
LOG_LEVEL=INFO
RUNTIME__DLTHUB_TELEMETRY=false
SQLMESH__DISABLE_ANONYMIZED_ANALYTICS=true

# Per-source ingest window overrides (defaults: 30)
# DATABOX_EBIRD_DAYS_BACK=30
# DATABOX_NOAA_DAYS_BACK=30
# DATABOX_USGS_DAYS_BACK=30

# OpenLineage — unset by default. Dagster attaches the OpenLineage sensor
# at startup when OPENLINEAGE_URL is set. Point at Marquez / DataHub /
# OpenMetadata / Atlan / Astro — every major lineage catalog speaks
# OpenLineage. See docs/observability.md. Requires `uv sync --extra lineage`.
# OPENLINEAGE_URL=http://localhost:5000
# OPENLINEAGE_NAMESPACE=databox
# OPENLINEAGE_API_KEY=

# Cloudflare Workers AI (required by the local Birding Trip Copilot agent)
# Only @cf/zai-org/glm-5.2 is permitted by the runtime.
# MODEL_BASE_URL accepts this exact identifier (and derives Cloudflare's official
# account endpoint) or an HTTPS api.cloudflare.com Workers AI URL.
CF_WORKERS_AI_API_KEY=
CF_WORKERS_AI_ACCOUNT_ID=
CF_WORKERS_AI_MODEL_BASE_URL=@cf/zai-org/glm-5.2

# Pipeline API Keys (add keys for each registered pipeline)
EBIRD_API_TOKEN=your_ebird_api_token_here
NOAA_API_TOKEN=your_noaa_api_token_here
XENO_CANTO_API_KEY=your_xeno_canto_api_key_here
