# Databox Environment Configuration

# Database (PostgreSQL)
DATABASE_URL=postgresql://databox:databox@localhost:5432/databox

# PostgreSQL connection details (used by SQLMesh config.yaml)
POSTGRES_HOST=localhost
POSTGRES_DB=databox
POSTGRES_USER=databox
POSTGRES_PASSWORD=databox

# DLT Configuration
DLT_DATA_DIR=data/dlt

# SQLMesh Configuration
SQLMESH_PROJECT_ROOT=transformations
SQLMESH_GATEWAY=postgres

# Logging
LOG_LEVEL=INFO

# Pipeline API Keys (add keys for each registered pipeline)
EBIRD_API_TOKEN=your_ebird_api_token_here
NOAA_API_TOKEN=your_noaa_api_token_here
