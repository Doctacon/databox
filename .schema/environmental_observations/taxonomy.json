{
  "_version": "1.0",
  "_name": "environmental_observations",
  "BirdObservation": {
    "description": "Individual eBird observation records with species, observation date/time, location, count, and region fields.",
    "use_cases": [
      "date/location analysis across environmental observations"
    ],
    "references": [
      "recent_observations",
      "notable_observations",
      "observation",
      "species"
    ],
    "tables": [
      {
        "table": "recent_observations",
        "source_pipeline": "ebird_api",
        "role": "primary"
      },
      {
        "table": "notable_observations",
        "source_pipeline": "ebird_api",
        "role": "secondary"
      }
    ],
    "natural_key": null,
    "assumptions": []
  },
  "Species": {
    "description": "Conformed bird species/taxon concept across eBird taxonomy/species lists, GBIF occurrence taxonomy, and Xeno-canto recording metadata.",
    "use_cases": [
      "date/location analysis across environmental observations",
      "birding trip planning evidence"
    ],
    "references": [
      "species_list",
      "taxonomy",
      "species_code",
      "sci_name",
      "com_name",
      "accepted_scientific_name",
      "accepted_taxon_key",
      "taxon_key",
      "genus",
      "english_name",
      "normalized_scientific_name"
    ],
    "tables": [
      {
        "table": "taxonomy",
        "source_pipeline": "ebird_api",
        "role": "primary"
      },
      {
        "table": "species_list",
        "source_pipeline": "ebird_api",
        "role": "secondary"
      },
      {
        "table": "taxonomy__com_name_codes",
        "source_pipeline": "ebird_api",
        "role": "child"
      },
      {
        "table": "taxonomy__sci_name_codes",
        "source_pipeline": "ebird_api",
        "role": "child"
      },
      {
        "table": "taxonomy__banding_codes",
        "source_pipeline": "ebird_api",
        "role": "child"
      },
      {
        "table": "occurrences",
        "source_pipeline": "gbif_api",
        "role": "secondary_taxonomy"
      },
      {
        "table": "recordings",
        "source_pipeline": "xeno_canto_api",
        "role": "media_context"
      }
    ],
    "natural_key": "normalized_scientific_name",
    "assumptions": [
      "Conform eBird, GBIF, and Xeno-canto species using normalized scientific name: lowercase/trim and strip trailing parenthetical authorship when present.",
      "eBird taxonomy wins conflicting descriptive attributes; GBIF fills taxon identifiers and gaps; Xeno-canto supplies media context.",
      "Coverage is a union of species from any source; rows without a usable scientific-name key remain source-scoped by fallback key.",
      "Normalization does not collapse hybrids or subspecies to a broader species unless the source scientific-name text matches after author stripping."
    ]
  },
