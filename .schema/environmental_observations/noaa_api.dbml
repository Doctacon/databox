Table "_dlt_version" [note: 'excluded: dlt internal schema version table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_name" text [not null]
  "version_hash" text [not null]
  "schema" text [not null]
}

Table "_dlt_loads" [note: 'excluded: dlt internal load tracking table'] {
  "load_id" text [not null]
  "schema_name" text
  "status" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_version_hash" text
}

Table "daily_weather" [note: 'concept: WeatherObservation | role: primary'] {
  "date" text [primary_key, not null]
  "datatype" text [primary_key, not null]
  "station" text [primary_key, not null]
  "value" double
  "attributes" text
  "source" text
  "_location_id" text
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "stations" [note: 'concept: WeatherStation | role: primary'] {
  "id" text [primary_key, not null]
  "name" text
  "latitude" double
  "longitude" double
  "elevation" double
  "elevation_unit" text
  "mindate" text
  "maxdate" text
  "datacoverage" double
  "_location_id" text
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "datasets" [note: 'excluded: NOAA source dataset metadata, not a date/location observation or location entity'] {
  "id" text [primary_key, not null]
  "name" text
  "datacoverage" double
  "mindate" text
  "maxdate" text
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "_dlt_pipeline_state" [note: 'excluded: dlt internal pipeline state table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "pipeline_name" text [not null]
  "state" text [not null]
  "created_at" timestamp [not null]
  "version_hash" text
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}
