edges.OBSERVED_AT
from	to	via	inferred
:Entity:BirdObservation	:Entity:BirdHotspot	ebird_api.recent_observations.loc_id -> ebird_api.hotspots.loc_id	true
:Entity:BirdObservation	:Entity:BirdHotspot	ebird_api.notable_observations.loc_id -> ebird_api.hotspots.loc_id	true
:Entity:WeatherObservation	:Entity:WeatherStation	noaa_api.daily_weather.station -> noaa_api.stations.id	true
:Entity:StreamflowObservation	:Entity:StreamgageSite	usgs_api.daily_values.site_no -> usgs_api.sites.site_no	true

edges.OBSERVED_SPECIES
from	to	via	inferred
:Entity:BirdObservation	:Entity:Species	ebird_api.recent_observations.species_code -> ebird_api.taxonomy/species_list.species_code	true
:Entity:BirdObservation	:Entity:Species	ebird_api.notable_observations.species_code -> ebird_api.taxonomy/species_list.species_code	true

edges.STITCHED_BY
from	to	via	inferred
:Entity:Species	:Entity:Species	normalized_scientific_name	false
