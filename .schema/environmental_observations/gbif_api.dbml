Table "_dlt_version" [note: 'excluded: dlt internal schema version table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_name" text [not null]
  "version_hash" text [not null]
  "schema" text [not null]
}

Table "_dlt_loads" [note: 'excluded: dlt internal load tracking table'] {
  "load_id" text [not null]
  "schema_name" text
  "status" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_version_hash" text
}

Table "occurrences" [note: 'concept: BirdOccurrence | role: primary | also_concept: Species | species_natural_key: accepted_scientific_name/scientific_name/species'] {
  "key" bigint [primary_key, not null]
  "gbif_id" text
  "occurrence_id" text
  "dataset_key" text
  "publishing_org_key" text
  "installation_key" text
  "hosting_organization_key" text
  "protocol" text
  "publishing_country" text
  "scientific_name" text
  "accepted_scientific_name" text
  "vernacular_name" text
  "kingdom" text
  "phylum" text
  "class_name" text
  "order_name" text
  "family" text
  "genus" text
  "species" text
  "generic_name" text
  "specific_epithet" text
  "taxon_rank" text
  "taxon_key" bigint
  "accepted_taxon_key" bigint
  "kingdom_key" bigint
  "phylum_key" bigint
  "class_key" bigint
  "order_key" bigint
  "family_key" bigint
  "genus_key" bigint
  "species_key" bigint
  "decimal_latitude" double
  "decimal_longitude" double
  "coordinate_uncertainty_in_meters" double
  "country" text
  "country_code" text
  "state_province" text
  "locality" text
  "event_date" text
  "year" bigint
  "month" bigint
  "day" bigint
  "basis_of_record" text
  "occurrence_status" text
  "establishment_means" text
  "record_number" text
  "recorded_by" text
  "identified_by" text
  "institution_code" text
  "collection_code" text
  "catalog_number" text
  "license" text
  "references" text
  "last_interpreted" text
  "last_crawled" text
  "last_parsed" text
  "_source_url" text
  "_query_country_code" text
  "_query_state_province" text
  "_query_taxon_key" bigint
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}
