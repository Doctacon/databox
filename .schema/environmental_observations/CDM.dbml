  common_name varchar
  kingdom varchar
  phylum varchar
  class_name varchar
  order_name varchar
  family varchar
  genus varchar
  species varchar
  generic_name varchar
  specific_epithet varchar
  taxon_rank varchar
  taxon_key bigint
  accepted_taxon_key bigint
  kingdom_key bigint
  phylum_key bigint
  class_key bigint
  order_key bigint
  family_key bigint
  genus_key bigint
  species_key bigint
  latitude double
  longitude double
  coordinate_uncertainty_in_meters double
  country varchar
  country_code varchar
  state_province varchar
  locality varchar
  event_date_text varchar
  event_date date
  year bigint
  month bigint
  day bigint
  basis_of_record varchar
  occurrence_status varchar
  establishment_means varchar
  record_number varchar
  recorded_by varchar
  identified_by varchar
  institution_code varchar
  collection_code varchar
  catalog_number varchar
  license varchar
  source_reference_url varchar
  last_interpreted varchar
  last_crawled varchar
  last_parsed varchar
  source_url varchar
  query_country_code varchar
  query_state_province varchar
  query_taxon_key bigint
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}

Table fact_bird_sound_recording [note: 'table_type:fact; grain:one row per Xeno-canto bird sound recording id; source_entity:BirdSoundRecording; media_storage:external_link_only'] {
  bird_sound_recording_sk varchar [pk, note: 'Stable string hash of source_pipeline and Xeno-canto recording id']
  species_sk varchar [not null, ref: > dim_species.species_sk]
  source_pipeline varchar [not null]
  source_id varchar [not null, note: 'Xeno-canto recording id']
  recording_id varchar
  genus varchar
  species varchar
  subspecies varchar
  group_name varchar
  english_name varchar
  recordist varchar
  country varchar
  locality varchar
  latitude double
  longitude double
  altitude varchar
  recording_type varchar
  sex varchar
  stage varchar
  method varchar
  recording_url varchar
  audio_file_url varchar [note: 'external media link; audio is not downloaded by the CDM']
  file_name varchar
  sonogram varchar
  oscillogram varchar
  license varchar
  quality varchar
  length varchar
  recording_time varchar
  recording_date_text varchar
  recording_date date
  uploaded_at varchar
  also_species varchar
  remarks varchar
  bird_seen varchar
  animal_seen varchar
  playback_used varchar
  temperature varchar
  registration_number varchar
  automatic_recording varchar
  device varchar
  microphone varchar
  source_url varchar
  query varchar
  query_page bigint
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}

Table fact_region_daily_stats [note: 'table_type:fact; grain:one row per eBird region per calendar date; source_entity:RegionDailyStats'] {
  region_daily_stats_sk varchar [pk, note: 'Stable string hash of source_pipeline, region_code, year, month, and day']
  source_pipeline varchar [not null]
  source_id varchar [not null, note: 'region_code|year|month|day']
  region_code varchar [not null]
  stats_date date
  year bigint
  month bigint
  day bigint
  num_checklists bigint
  num_contributors bigint
  num_species bigint
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}

Table fact_weather_observation [note: 'table_type:fact; grain:one row per NOAA station per observation date per datatype; source_entity:WeatherObservation'] {
  weather_observation_sk varchar [pk, note: 'Stable string hash of source_pipeline, station, date, and datatype']
  weather_station_sk varchar [not null, ref: > dim_weather_station.weather_station_sk]
  source_pipeline varchar [not null]
  source_id varchar [not null, note: 'station|date|datatype']
  station_id varchar
  observation_date date
  datatype varchar
  value double
  attributes varchar
  source varchar
  location_id varchar
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}

Table fact_streamflow_observation [note: 'table_type:fact; grain:one row per USGS streamgage site per observation date per parameter code; source_entity:StreamflowObservation'] {
  streamflow_observation_sk varchar [pk, note: 'Stable string hash of source_pipeline, site_no, observation_date, and parameter_cd']
  streamgage_site_sk varchar [not null, ref: > dim_streamgage_site.streamgage_site_sk]
  source_pipeline varchar [not null]
  source_id varchar [not null, note: 'site_no|observation_date|parameter_cd']
  site_no varchar
  site_name varchar
  observation_date date
  parameter_cd varchar
  parameter_name varchar
  unit_cd varchar
  value double
  qualifier varchar
  state_cd varchar
  latitude double
  longitude double
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}

Table fact_earthquake_event [note: 'table_type:fact; grain:one row per USGS earthquake event id; source_entity:EarthquakeEvent'] {
  earthquake_event_sk varchar [pk, note: 'Stable string hash of source_pipeline and event id']
  source_pipeline varchar [not null]
  source_id varchar [not null, note: 'USGS earthquake event id']
  event_id varchar [not null]
  magnitude double
  magnitude_type varchar
  place varchar
  title varchar
  event_time timestamp
  event_updated_at timestamp
  longitude double
  latitude double
  depth_km double
  status varchar
  tsunami_flag bigint
  significance bigint
  event_type varchar
  alert varchar
  url varchar
  loaded_at timestamp
  dlt_load_id varchar
  dlt_id varchar
}
