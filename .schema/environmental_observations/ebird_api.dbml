Table "_dlt_version" [note: 'excluded: dlt internal schema version table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_name" text [not null]
  "version_hash" text [not null]
  "schema" text [not null]
}

Table "_dlt_loads" [note: 'excluded: dlt internal load tracking table'] {
  "load_id" text [not null]
  "schema_name" text
  "status" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_version_hash" text
}

Table "recent_observations" [note: 'concept: BirdObservation | role: primary'] {
  "how_many" bigint
  "lat" double
  "lng" double
  "species_code" text
  "com_name" text
  "sci_name" text
  "loc_id" text
  "loc_name" text
  "obs_dt" timestamp
  "obs_valid" bool
  "obs_reviewed" bool
  "location_private" bool
  "sub_id" text [primary_key, not null]
  "exotic_category" text
  "_region_code" text
  "_loaded_at" timestamp
  "_observation_date" timestamp
  "_is_notable" bool
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "notable_observations" [note: 'concept: BirdObservation | role: secondary'] {
  "how_many" bigint
  "lat" double
  "lng" double
  "species_code" text
  "com_name" text
  "sci_name" text
  "loc_id" text
  "loc_name" text
  "obs_dt" timestamp
  "obs_valid" bool
  "obs_reviewed" bool
  "location_private" bool
  "sub_id" text [primary_key, not null]
  "_region_code" text
  "_loaded_at" timestamp
  "_observation_date" timestamp
  "_is_notable" bool
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
  "exotic_category" text
}

Table "species_list" [note: 'concept: Species | role: secondary'] {
  "species_code" text [primary_key, not null]
  "region" text
  "order" bigint
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "hotspots" [note: 'concept: BirdHotspot | role: primary'] {
  "lat" double
  "lng" double
  "num_species_all_time" bigint
  "loc_id" text [primary_key, not null]
  "loc_name" text
  "country_code" text
  "subnational1_code" text
  "subnational2_code" text
  "latest_obs_dt" timestamp
  "num_checklists_all_time" bigint
  "_loaded_at" timestamp
  "_region_code" text
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "taxonomy" [note: 'concept: Species | role: primary'] {
  "sci_name" text [primary_key, not null]
  "com_name" text
  "species_code" text
  "category" text
  "taxon_order" double
  "order" text
  "family_code" text
  "family_com_name" text
  "family_sci_name" text
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
  "report_as" text
  "extinct" bool
  "extinct_year" bigint
}

Table "region_stats" [note: 'concept: RegionDailyStats | role: primary'] {
  "region_code" text [primary_key, not null]
  "year" bigint [primary_key, not null]
  "month" bigint [primary_key, not null]
  "day" bigint [primary_key, not null]
  "date" text
  "num_checklists" bigint
  "num_contributors" bigint
  "num_species" bigint
  "_loaded_at" timestamp
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "_dlt_pipeline_state" [note: 'excluded: dlt internal pipeline state table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "pipeline_name" text [not null]
  "state" text [not null]
  "created_at" timestamp [not null]
  "version_hash" text
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "taxonomy__com_name_codes" [note: 'concept: Species | role: child'] {
  "value" text
  "_dlt_parent_id" text [not null]
  "_dlt_list_idx" bigint [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "taxonomy__sci_name_codes" [note: 'concept: Species | role: child'] {
  "value" text
  "_dlt_parent_id" text [not null]
  "_dlt_list_idx" bigint [not null]
  "_dlt_id" text [not null, unique, row_key]
}

Table "taxonomy__banding_codes" [note: 'concept: Species | role: child'] {
