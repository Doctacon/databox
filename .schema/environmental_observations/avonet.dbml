Table "_dlt_version" [note: 'excluded: dlt internal schema version table'] {
  "version" bigint [not null]
  "engine_version" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_name" text [not null]
  "version_hash" text [not null]
  "schema" text [not null]
}

Table "_dlt_loads" [note: 'excluded: dlt internal load tracking table'] {
  "load_id" text [not null]
  "schema_name" text
  "status" bigint [not null]
  "inserted_at" timestamp [not null]
  "schema_version_hash" text
}

Table "species_traits" [note: 'concept: BirdSpeciesTraits | role: primary | also_concept: Species | species_natural_key: source_scientific_name | grain: one AVONET v7 eBird-aligned species row | publication: validated atomic snapshot from transient Quack staging'] {
  "source_scientific_name" text [not null, note: 'Scientific name from AVONET Species2; the source species identity used for exact conformance.']
  "family" text [not null, note: 'Taxonomic family from AVONET Family2.']
  "order_name" text [not null, note: 'Taxonomic order from AVONET Order2.']
  "avibase_id" text [primary_key, not null, note: 'AVONET Avibase.ID2 source identifier.']
  "total_individuals" bigint [not null, note: 'Count of individuals contributing to species-average measurements.']
  "female_individuals" bigint [not null, note: 'Count of identified female individuals.']
  "male_individuals" bigint [not null, note: 'Count of identified male individuals.']
  "unknown_sex_individuals" bigint [not null, note: 'Count of individuals whose sex is unknown.']
  "complete_measures" bigint [not null, note: 'Count of individuals with the complete measurement set.']
  "beak_length_culmen_mm" double [note: 'Species-average beak length measured along the culmen, in millimetres.']
  "beak_length_nares_mm" double [note: 'Species-average beak length from the nares, in millimetres.']
  "beak_width_mm" double [note: 'Species-average beak width, in millimetres.']
  "beak_depth_mm" double [note: 'Species-average beak depth, in millimetres.']
  "tarsus_length_mm" double [note: 'Species-average tarsus length, in millimetres.']
  "wing_length_mm" double [note: 'Species-average wing length, in millimetres.']
  "kipps_distance_mm" double [note: 'Species-average Kipp distance, in millimetres.']
  "secondary_length_mm" double [note: 'Species-average first-secondary length, in millimetres.']
  "hand_wing_index" double [note: 'Dimensionless hand-wing index derived from wing length and Kipp distance.']
  "tail_length_mm" double [note: 'Species-average tail length, in millimetres.']
  "mass_g" double [note: 'Species-average body mass, in grams.']
  "mass_source" text [note: 'AVONET categorical source for the body-mass value; exact source value is retained.']
  "mass_reference_other" text [note: 'Other cited mass reference when supplied by AVONET.']
  "inference" boolean [not null, note: 'True only when AVONET Inference is YES, indicating at least one inferred trait.']
  "traits_inferred" text [note: 'Exact AVONET semicolon-delimited list of inferred traits; null when the source cell is blank or NA.']
  "reference_species" text [note: 'AVONET reference species used for inference; null when the source cell is blank or NA.']
  "habitat" text [note: 'AVONET habitat category; null when the exact source value is NA.']
  "habitat_density_code" bigint [not null, note: 'AVONET habitat-density code: 1 dense, 2 semi-open, 3 open.']
  "migration_code" bigint [note: 'AVONET migration code: 1 sedentary, 2 partial migrant, 3 migratory; null for exact source NA.']
  "trophic_level" text [note: 'AVONET trophic-level category; null when the exact source value is NA.']
  "trophic_niche" text [note: 'AVONET trophic-niche category; null when the exact source value is NA.']
  "primary_lifestyle" text [not null, note: 'AVONET primary-lifestyle category.']
  "dataset_doi" text [not null, note: 'Pinned dataset DOI: 10.6084/m9.figshare.16586228.v7.']
  "dataset_version" text [not null, note: 'Pinned AVONET dataset version: v7.']
  "dataset_license" text [not null, note: 'Dataset license: CC BY 4.0.']
  "source_file_id" bigint [not null, note: 'Pinned Figshare file identifier: 34480856.']
  "source_file_md5" text [not null, note: 'Validated pinned workbook MD5: 1445afdcfb6df784010c2ca034544bc8.']
  "source_url" text [not null, note: 'Fixed HTTPS Figshare downloader URL; transient signed redirect URLs are not retained.']
  "loaded_at" timestamp [not null, note: 'UTC timestamp assigned once for the validated snapshot load.']
  "_dlt_load_id" text [not null]
  "_dlt_id" text [not null, unique, row_key]
}
