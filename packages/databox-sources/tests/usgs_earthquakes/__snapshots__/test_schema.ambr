      columns:
        _dlt_id:
          data_type: text
          nullable: false
          row_key: true
          unique: true
        _dlt_load_id:
          data_type: text
          nullable: false
        created_at:
          data_type: timestamp
          nullable: false
        engine_version:
          data_type: bigint
          nullable: false
        pipeline_name:
          data_type: text
          nullable: false
        state:
          data_type: text
          nullable: false
        version:
          data_type: bigint
          nullable: false
        version_hash:
          data_type: text
          nullable: true
      file_format: preferred
